{
  "name": "satanio/nette-sdk-skeleton-sdk",
  "description": "Skeleton for Satanio PHP SDKs",
  "type": "library",
  "require": {
    "php": ">=8.3",
    "ext-json": "*",
    "guzzlehttp/guzzle": "^7.0",
    "lcobucci/jwt": "^5.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.19",
    "nette/di": "^3.0",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "phpstan/phpstan-nette": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpunit/phpunit": "^12.5",
    "roave/no-floaters": "^1.15",
    "shipmonk/phpstan-rules": "^4.3",
    "slevomat/coding-standard": "^8.26",
    "squizlabs/php_codesniffer": "*",
    "symplify/easy-coding-standard": "^13.2"
  },
  "autoload": {
    "psr-4": {
      "Satanio\\SdkSkeleton\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": false,
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "ecs": "vendor/bin/ecs --config=ecs.php",
    "ecs-fix": "vendor/bin/ecs --config=ecs.php --fix",
    "phpstan": "phpstan analyse -c phpstan.neon",
    "test": "phpunit",
    "qa": [
      "@ecs",
      "@phpstan",
      "@test"
    ]
  }
}
