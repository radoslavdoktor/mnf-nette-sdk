{
  "name": "satanio/sdk-skeleton",
  "description": "Skeleton for Satanio PHP SDKs",
  "type": "library",
  "require": {
    "php": ">=8.3",
    "guzzlehttp/guzzle": "^7.0",
    "lcobucci/jwt": "^5.0",
    "nette/utils": "^3.0 || ^4.0"
  },
  "require-dev": {
    "fakerphp/faker": "^1.19",
    "nette/di": "^3.0",
    "nette/tester": "^2.5",
    "nepada/phpstan-nette-tester": "^2.0",
    "phpstan/extension-installer": "^1.3",
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-deprecation-rules": "^2.0",
    "phpstan/phpstan-nette": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Satanio\\SdkSkeleton\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "scripts": {
    "phpstan": [
      "phpstan analyse -c phpstan.neon"
    ],
    "test": [
      "tester -C tests"
    ],
    "qa": [
      "@phpstan",
      "@test"
    ]
  }
}
